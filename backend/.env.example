# ==============================================================================
# ImAction CKA - Environment Variables Template
# Copy this file to '.env' and fill in your actual credentials.
# ==============================================================================

# Application Configurations
APP_NAME="ImAction CKA"
APP_ENV=development # Options: development, staging, production
DEBUG=true
API_V1_STR=/api/v1
SECRET_KEY=super-secret-key-change-me-in-production

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=imaction_cka

# Database URLs
# Note: For async SQLAlchemy, we use postgresql+asyncpg://
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/imaction_cka
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/imaction_cka
