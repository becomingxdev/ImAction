# ==============================================================================
# ImAction CKA — Environment Variables Reference
# Copy this file to .env for LOCAL development only.
# On Google Cloud Run, set ALL of these via Cloud Run → Edit & Deploy → Variables.
# NEVER commit .env to git.
# ==============================================================================

# ── Core Application ──────────────────────────────────────────────────────────
APP_NAME=ImAction
APP_ENV=development          # production | staging | development
DEBUG=false
API_V1_STR=/api/v1
SECRET_KEY=replace-me-with-a-strong-random-secret

# ── AI Providers ──────────────────────────────────────────────────────────────
# Options: "gemini" (production) | "mock" (local no-creds dev only)
EMBEDDING_PROVIDER=gemini
LLM_PROVIDER=gemini

# Gemini model — must be a GA model available on Vertex AI
GEMINI_MODEL=gemini-2.0-flash

# ── Google Cloud / Vertex AI ──────────────────────────────────────────────────
# On Cloud Run these are set automatically if you configure the service account.
# For LOCAL dev with gcloud: run `gcloud auth application-default login` and
# set GOOGLE_CLOUD_PROJECT below — no API key needed.
GOOGLE_CLOUD_PROJECT=imaction
GOOGLE_CLOUD_LOCATION=us-central1

# Only needed if NOT using Vertex AI / ADC (e.g. direct Gemini API from personal key)
# GEMINI_API_KEY=your-api-key-here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Add your Firebase Hosting URL here for production
# CORS_ORIGINS=["https://imaction-xyz.web.app","http://localhost:5173"]

# ── PostgreSQL (optional — not required for MVP) ──────────────────────────────
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=imaction_cka
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/imaction_cka
# ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/imaction_cka
